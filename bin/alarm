#!/bin/bash
#
# Codex Alarm: local macOS notifications for Codex CLI lifecycle hooks.

VERSION="1.1.0"

env_was_set() {
  [ "${!1+x}" = "x" ]
}

ORIG_BACKEND="${CODEX_ALARM_BACKEND-}"
ORIG_BUNDLE_ID="${CODEX_ALARM_ACTIVATE_BUNDLE_ID-}"
ORIG_SOUND="${CODEX_ALARM_SOUND-}"
ORIG_NOTIFY_STOP="${CODEX_ALARM_NOTIFY_ON_STOP-}"
ORIG_NOTIFY_PERMISSION="${CODEX_ALARM_NOTIFY_ON_PERMISSION-}"
ORIG_BACKEND_TIMEOUT="${CODEX_ALARM_BACKEND_TIMEOUT_SECONDS-}"
ORIG_ALLOW_OSASCRIPT_FALLBACK="${CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK-}"
HAS_BACKEND=0; env_was_set CODEX_ALARM_BACKEND && HAS_BACKEND=1
HAS_BUNDLE_ID=0; env_was_set CODEX_ALARM_ACTIVATE_BUNDLE_ID && HAS_BUNDLE_ID=1
HAS_SOUND=0; env_was_set CODEX_ALARM_SOUND && HAS_SOUND=1
HAS_NOTIFY_STOP=0; env_was_set CODEX_ALARM_NOTIFY_ON_STOP && HAS_NOTIFY_STOP=1
HAS_NOTIFY_PERMISSION=0; env_was_set CODEX_ALARM_NOTIFY_ON_PERMISSION && HAS_NOTIFY_PERMISSION=1
HAS_BACKEND_TIMEOUT=0; env_was_set CODEX_ALARM_BACKEND_TIMEOUT_SECONDS && HAS_BACKEND_TIMEOUT=1
HAS_ALLOW_OSASCRIPT_FALLBACK=0; env_was_set CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK && HAS_ALLOW_OSASCRIPT_FALLBACK=1

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
CODEX_ALARM_HOME="${CODEX_ALARM_HOME:-$CODEX_HOME/alarm}"
CONFIG_FILE="$CODEX_ALARM_HOME/config"

CODEX_ALARM_BACKEND="auto"
CODEX_ALARM_ACTIVATE_BUNDLE_ID=""
CODEX_ALARM_SOUND="Glass"
CODEX_ALARM_NOTIFY_ON_STOP="1"
CODEX_ALARM_NOTIFY_ON_PERMISSION="1"
CODEX_ALARM_BACKEND_TIMEOUT_SECONDS="3"
CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK="0"
CONFIG_ERROR=""

set_config_error() {
  [ -n "$CONFIG_ERROR" ] || CONFIG_ERROR="$1"
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

strip_quotes() {
  local value="$1"
  if [[ "$value" == \"*\" && "$value" == *\" ]]; then
    value="${value#\"}"
    value="${value%\"}"
  elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
    value="${value#\'}"
    value="${value%\'}"
  fi
  printf '%s' "$value"
}

load_config() {
  [ -f "$CONFIG_FILE" ] || return 0

  local line key value line_number=0
  while IFS= read -r line || [ -n "$line" ]; do
    line_number=$((line_number + 1))
    line="${line%%#*}"
    line="$(trim "$line")"
    [ -n "$line" ] || continue
    if [[ "$line" != *=* ]]; then
      set_config_error "$CONFIG_FILE:$line_number: expected KEY=VALUE"
      continue
    fi
    key="$(trim "${line%%=*}")"
    value="$(trim "${line#*=}")"
    value="$(strip_quotes "$value")"
    if [ -z "$key" ]; then
      set_config_error "$CONFIG_FILE:$line_number: missing key"
      continue
    fi

    case "$key" in
      CODEX_ALARM_BACKEND)
        case "$value" in
          auto|terminal-notifier|osascript) CODEX_ALARM_BACKEND="$value" ;;
          *)
            set_config_error "$CONFIG_FILE:$line_number: invalid CODEX_ALARM_BACKEND '$value'"
            CODEX_ALARM_BACKEND="$value"
            ;;
        esac
        ;;
      CODEX_ALARM_ACTIVATE_BUNDLE_ID) CODEX_ALARM_ACTIVATE_BUNDLE_ID="$value" ;;
      CODEX_ALARM_SOUND) CODEX_ALARM_SOUND="$value" ;;
      CODEX_ALARM_NOTIFY_ON_STOP)
        case "$value" in
          0|1) CODEX_ALARM_NOTIFY_ON_STOP="$value" ;;
          *)
            set_config_error "$CONFIG_FILE:$line_number: CODEX_ALARM_NOTIFY_ON_STOP must be 0 or 1"
            CODEX_ALARM_NOTIFY_ON_STOP="$value"
            ;;
        esac
        ;;
      CODEX_ALARM_NOTIFY_ON_PERMISSION)
        case "$value" in
          0|1) CODEX_ALARM_NOTIFY_ON_PERMISSION="$value" ;;
          *)
            set_config_error "$CONFIG_FILE:$line_number: CODEX_ALARM_NOTIFY_ON_PERMISSION must be 0 or 1"
            CODEX_ALARM_NOTIFY_ON_PERMISSION="$value"
            ;;
        esac
        ;;
      CODEX_ALARM_BACKEND_TIMEOUT_SECONDS)
        if [[ "$value" =~ ^[0-9]+$ ]] && [ "$value" -ge 1 ]; then
          CODEX_ALARM_BACKEND_TIMEOUT_SECONDS="$value"
        else
          set_config_error "$CONFIG_FILE:$line_number: CODEX_ALARM_BACKEND_TIMEOUT_SECONDS must be a positive integer"
          CODEX_ALARM_BACKEND_TIMEOUT_SECONDS="$value"
        fi
        ;;
      CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK)
        case "$value" in
          0|1) CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK="$value" ;;
          *)
            set_config_error "$CONFIG_FILE:$line_number: CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK must be 0 or 1"
            CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK="$value"
            ;;
        esac
        ;;
    esac
  done < "$CONFIG_FILE"
}

apply_env_overrides() {
  [ "$HAS_BACKEND" -eq 1 ] && CODEX_ALARM_BACKEND="$ORIG_BACKEND"
  [ "$HAS_BUNDLE_ID" -eq 1 ] && CODEX_ALARM_ACTIVATE_BUNDLE_ID="$ORIG_BUNDLE_ID"
  [ "$HAS_SOUND" -eq 1 ] && CODEX_ALARM_SOUND="$ORIG_SOUND"
  [ "$HAS_NOTIFY_STOP" -eq 1 ] && CODEX_ALARM_NOTIFY_ON_STOP="$ORIG_NOTIFY_STOP"
  [ "$HAS_NOTIFY_PERMISSION" -eq 1 ] && CODEX_ALARM_NOTIFY_ON_PERMISSION="$ORIG_NOTIFY_PERMISSION"
  [ "$HAS_BACKEND_TIMEOUT" -eq 1 ] && CODEX_ALARM_BACKEND_TIMEOUT_SECONDS="$ORIG_BACKEND_TIMEOUT"
  [ "$HAS_ALLOW_OSASCRIPT_FALLBACK" -eq 1 ] && CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK="$ORIG_ALLOW_OSASCRIPT_FALLBACK"
}

detect_bundle_id() {
  if [ "$HAS_BUNDLE_ID" -eq 1 ]; then
    printf '%s' "$CODEX_ALARM_ACTIVATE_BUNDLE_ID"
    return 0
  fi

  if [ -n "$CODEX_ALARM_ACTIVATE_BUNDLE_ID" ]; then
    printf '%s' "$CODEX_ALARM_ACTIVATE_BUNDLE_ID"
    return 0
  fi

  case "${TERM_PROGRAM-}" in
    Apple_Terminal) printf '%s' "com.apple.Terminal" ;;
    iTerm.app) printf '%s' "com.googlecode.iterm2" ;;
    vscode) printf '%s' "com.microsoft.VSCode" ;;
    Cursor) printf '%s' "com.todesktop.230313mzl4w4u92" ;;
    ghostty|Ghostty) printf '%s' "com.mitchellh.ghostty" ;;
    WarpTerminal) printf '%s' "dev.warp.Warp-Stable" ;;
    *) printf '%s' "" ;;
  esac
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

resolve_backend() {
  case "$CODEX_ALARM_BACKEND" in
    terminal-notifier)
      printf '%s' "terminal-notifier"
      ;;
    osascript)
      printf '%s' "osascript"
      ;;
    auto|*)
      printf '%s' "terminal-notifier"
      ;;
  esac
}

osascript_fallback_allowed() {
  [ "$CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK" = "1" ]
}

log_message() {
  mkdir -p "$CODEX_ALARM_HOME" 2>/dev/null || return 0
  [ -d "$CODEX_ALARM_HOME" ] || return 0
  printf '%s %s\n' "$(date '+%Y-%m-%dT%H:%M:%S%z')" "$*" >> "$CODEX_ALARM_HOME/alarm.log" 2>/dev/null || true
}

log_field() {
  local value="$1"
  value="${value//$'\r'/ }"
  value="${value//$'\n'/ }"
  value="${value//|/ }"
  value="$(trim "$value")"
  [ -n "$value" ] || value="-"
  printf '%s' "$value"
}

log_notification_attempt() {
  local event="$1"
  local backend="$2"
  local project="$3"
  local tool="$4"
  local detail="$5"

  case "$event" in
    stop|permission) ;;
    *) return 0 ;;
  esac

  log_message "event=$(log_field "$event") backend=$(log_field "$backend") project=$(log_field "$project") tool=$(log_field "$tool") detail=$(log_field "$detail")"
}

run_supervised_timeout() {
  local use_process_group="$1"
  local timeout_seconds="$2"
  local output_file="$3"
  local pid elapsed
  shift 3

  case "$timeout_seconds" in
    ""|*[!0-9]*) timeout_seconds=3 ;;
  esac
  [ "$timeout_seconds" -ge 1 ] 2>/dev/null || timeout_seconds=3

  if command_exists /usr/bin/perl; then
    /usr/bin/perl -e '
      use POSIX ":sys_wait_h";
      my $use_process_group = shift @ARGV;
      my $timeout = shift @ARGV;
      exit 127 unless @ARGV;
      my $pid = fork();
      exit 127 unless defined $pid;
      if ($pid == 0) {
        setpgrp(0, 0) or die "setpgrp failed: $!" if $use_process_group;
        exec @ARGV;
        print STDERR "exec failed: $!\n";
        exit 127;
      }
      my $deadline = time() + $timeout;
      while (1) {
        my $done = waitpid($pid, WNOHANG);
        if ($done == $pid) {
          exit(($? & 127) ? 128 + ($? & 127) : ($? >> 8));
        }
        last if time() >= $deadline;
        select undef, undef, undef, 0.1;
      }
      my $target = $use_process_group ? -$pid : $pid;
      kill "TERM", $target;
      select undef, undef, undef, 0.2;
      if (waitpid($pid, WNOHANG) == 0) {
        kill "KILL", $target;
        waitpid($pid, 0);
      }
      exit 124;
    ' "$use_process_group" "$timeout_seconds" "$@" > "$output_file" 2>&1
    return $?
  fi

  "$@" > "$output_file" 2>&1 &
  pid=$!
  elapsed=0
  while kill -0 "$pid" 2>/dev/null; do
    if [ "$elapsed" -ge "$timeout_seconds" ]; then
      kill "$pid" 2>/dev/null || true
      sleep 0.2
      kill -9 "$pid" 2>/dev/null || true
      wait "$pid" 2>/dev/null || true
      return 124
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done

  wait "$pid" 2>/dev/null
}

run_with_timeout() {
  run_supervised_timeout 0 "$@"
}

run_process_group_with_timeout() {
  run_supervised_timeout 1 "$@"
}

should_print_backend_output() {
  local event="$1"
  [ "${CODEX_ALARM_DRY_RUN:-0}" = "1" ] && return 0
  case "$event" in
    test|test-permission) return 0 ;;
    *) return 1 ;;
  esac
}

is_test_event() {
  case "$1" in
    test|test-permission) return 0 ;;
    *) return 1 ;;
  esac
}

should_retry_osascript_fallback() {
  local event="$1"
  local timeout_seconds="$CODEX_ALARM_BACKEND_TIMEOUT_SECONDS"

  osascript_fallback_allowed || return 1

  case "$timeout_seconds" in
    ""|*[!0-9]*) timeout_seconds=3 ;;
  esac
  [ "$timeout_seconds" -ge 1 ] 2>/dev/null || timeout_seconds=3

  case "$event" in
    stop|permission)
      [ "$timeout_seconds" -le 4 ]
      ;;
    *)
      return 0
      ;;
  esac
}

write_notification_jxa() {
  cat > "$1" <<'JXA'
ObjC.import('Foundation');

function run(argv) {
  var event = argv[0] || 'test';
  var backend = argv[1] || 'osascript';
  var bundleId = argv[2] || '';
  var sound = argv[3] || 'Glass';
  var alarmHome = argv[4] || '';
  var dryRun = argv[5] === '1';
  var payloadPath = argv[6] || '';
  var notifierPath = argv[7] || '';
  var mode = argv[8] || 'send';
  var app = Application.currentApplication();
  app.includeStandardAdditions = true;

  function readText(path) {
    try {
      return ObjC.unwrap($.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, null)) || '';
    } catch (error) {
      return '';
    }
  }

  function writeText(path, value) {
    var text = $.NSString.alloc.initWithUTF8String(String(value));
    return text.writeToFileAtomicallyEncodingError(path, true, $.NSUTF8StringEncoding, null);
  }

  function parsePayload(text) {
    try {
      return text ? JSON.parse(text) : {};
    } catch (error) {
      return {};
    }
  }

  function env(name) {
    var value = $.NSProcessInfo.processInfo.environment.objectForKey(name);
    return value ? ObjC.unwrap(value) : '';
  }

  function basename(path) {
    path = String(path || '').replace(/\/+$/, '');
    if (!path) return 'Codex';
    var parts = path.split('/');
    return parts[parts.length - 1] || 'Codex';
  }

  function firstLine(value) {
    return String(value || '').replace(/\r/g, '\n').split('\n')[0].trim();
  }

  function truncate(value, max) {
    value = firstLine(value);
    if (value.length <= max) return value;
    return value.slice(0, Math.max(0, max - 1)) + '…';
  }

  function pick(obj, keys) {
    for (var i = 0; i < keys.length; i++) {
      if (obj && obj[keys[i]] !== undefined && obj[keys[i]] !== null && String(obj[keys[i]]).trim() !== '') {
        return obj[keys[i]];
      }
    }
    return '';
  }

  function shellQuote(value) {
    return "'" + String(value).replace(/'/g, "'\\''") + "'";
  }

  function statePath() {
    return alarmHome ? alarmHome.replace(/\/+$/, '') + '/state.json' : '';
  }

  function shouldSuppressPermission(fingerprint) {
    if (event !== 'permission' || !alarmHome || dryRun) return false;
    var path = statePath();
    var now = Date.now();
    var state = {};
    try {
      state = JSON.parse(readText(path) || '{}');
    } catch (error) {
      state = {};
    }

    var suppress = state.last_permission_fingerprint === fingerprint &&
      typeof state.last_permission_time_ms === 'number' &&
      now - state.last_permission_time_ms <= 1000;

    return suppress;
  }

  function rememberPermission(fingerprint) {
    if (event !== 'permission' || !alarmHome || dryRun) return;
    var path = statePath();
    var state = {};
    try {
      state = JSON.parse(readText(path) || '{}');
    } catch (error) {
      state = {};
    }
    state.last_permission_fingerprint = fingerprint;
    state.last_permission_time_ms = Date.now();
    try {
      writeText(path, JSON.stringify(state, null, 2) + '\n');
    } catch (error) {}
  }

  function send(title, body) {
    if (dryRun) {
      console.log(JSON.stringify({
        event: event,
        backend: backend,
        title: title,
        body: body,
        activateBundleId: bundleId,
        sound: sound
      }));
      return true;
    }

    if (backend === 'terminal-notifier' && notifierPath) {
      var command = shellQuote(notifierPath) +
        ' -title ' + shellQuote(title) +
        ' -message ' + shellQuote(body) +
        ' -group ' + shellQuote('codex-alarm-' + event);
      if (sound) command += ' -sound ' + shellQuote(sound);
      if (bundleId) command += ' -activate ' + shellQuote(bundleId);
      try {
        app.doShellScript(command);
        return true;
      } catch (error) {
        console.log('ERROR terminal-notifier failed: ' + error);
      }
    }

    try {
      app.displayNotification(body, { withTitle: title, soundName: sound });
      return true;
    } catch (errorWithSound) {
      console.log('ERROR osascript notification with sound failed: ' + errorWithSound);
      try {
        app.displayNotification(body, { withTitle: title });
        return true;
      } catch (errorWithoutSound) {
        console.log('ERROR osascript notification failed: ' + errorWithoutSound);
        return false;
      }
    }
  }

  function mustSend(title, body) {
    if (!send(title, body)) {
      throw new Error('notification backend failed');
    }
  }

  function preparedPath(name) {
    return notifierPath.replace(/\/+$/, '') + '/' + name;
  }

  function prepareNotification(title, body, fingerprint, project, detail, toolName) {
    if (!notifierPath) throw new Error('prepare output directory missing');
    writeText(preparedPath('suppressed'), '0\n');
    writeText(preparedPath('title'), title);
    writeText(preparedPath('body'), body);
    writeText(preparedPath('fingerprint'), fingerprint || '');
    writeText(preparedPath('project'), project || '');
    writeText(preparedPath('detail'), detail || '');
    writeText(preparedPath('tool'), toolName || '');
  }

  function prepareSuppressed() {
    if (!notifierPath) throw new Error('prepare output directory missing');
    writeText(preparedPath('suppressed'), '1\n');
  }

  if (mode === 'remember') {
    rememberPermission(payloadPath);
    return;
  }

  var payload = parsePayload(readText(payloadPath));
  var cwd = pick(payload, ['cwd', 'working_directory', 'workingDirectory']) || env('PWD') || '';
  var folder = basename(cwd);
  var title = 'Codex Alarm';
  var detail = '';

  if (event === 'permission') {
    var toolInput = payload.tool_input || payload.toolInput || {};
    var toolName = pick(payload, ['tool_name', 'toolName']) || '';
    detail = pick(toolInput, ['description']) || toolName || pick(toolInput, ['cmd', 'command']) || 'Approval requested';
    detail = truncate(detail, 120);
    title = 'Codex needs approval';
    var fingerprint = ['permission', toolName, detail].join('|');
    if (shouldSuppressPermission(fingerprint)) {
      if (mode === 'prepare') prepareSuppressed();
      return;
    }
    if (mode === 'prepare') {
      prepareNotification(title, folder + ': ' + detail, fingerprint, folder, detail, toolName);
      return;
    }
    mustSend(title, folder + ': ' + detail);
    rememberPermission(fingerprint);
    return;
  }

  if (event === 'stop') {
    detail = pick(payload, ['last_assistant_message', 'last-assistant-message', 'lastAssistantMessage']);
    detail = truncate(detail || 'Waiting for your next instruction', 120);
    if (mode === 'prepare') {
      prepareNotification('Codex finished', folder + ': ' + detail, '', folder, detail, '');
      return;
    }
    mustSend('Codex finished', folder + ': ' + detail);
    return;
  }

  if (event === 'test-permission') {
    if (mode === 'prepare') {
      prepareNotification('Codex needs approval', folder + ': Test approval request', '', folder, 'Test approval request', '');
      return;
    }
    mustSend('Codex needs approval', folder + ': Test approval request');
    return;
  }

  if (mode === 'prepare') {
    prepareNotification('Codex Alarm test', folder + ': Notifications are working', '', folder, 'Notifications are working', '');
    return;
  }
  mustSend('Codex Alarm test', folder + ': Notifications are working');
}
JXA
}

run_notification_once() {
  local event="$1"
  local backend="$2"
  local bundle_id="$3"
  local payload_file="$4"
  local notifier_path="$5"
  local dry_run="$6"
  local output_file script_file prepare_dir status message title body fingerprint suppressed remember_output project detail tool
  local -a notifier_args

  output_file="${TMPDIR:-/tmp}/codex-alarm-backend.$$.$event.$backend.log"
  script_file="${TMPDIR:-/tmp}/codex-alarm-backend.$$.$event.$backend.js"
  if ! write_notification_jxa "$script_file" 2>/dev/null; then
    log_message "backend=$backend event=$event failed to prepare notification script"
    return 1
  fi

  if [ "$backend" = "terminal-notifier" ] && [ "$dry_run" != "1" ]; then
    prepare_dir="${TMPDIR:-/tmp}/codex-alarm-prepare.$$.$event.$backend"
    mkdir -p "$prepare_dir" 2>/dev/null || true
    run_with_timeout "$CODEX_ALARM_BACKEND_TIMEOUT_SECONDS" "$output_file" \
      /usr/bin/osascript -l JavaScript "$script_file" "$event" "$backend" "$bundle_id" "$CODEX_ALARM_SOUND" "$CODEX_ALARM_HOME" "$dry_run" "$payload_file" "$prepare_dir" "prepare"
    status=$?

    if [ "$status" -eq 0 ]; then
      suppressed="$(cat "$prepare_dir/suppressed" 2>/dev/null || true)"
      if [ "$suppressed" = "1" ]; then
        rm -rf "$prepare_dir" 2>/dev/null || true
        rm -f "$output_file" "$script_file" 2>/dev/null || true
        return 0
      fi

      title="$(cat "$prepare_dir/title" 2>/dev/null || true)"
      body="$(cat "$prepare_dir/body" 2>/dev/null || true)"
      fingerprint="$(cat "$prepare_dir/fingerprint" 2>/dev/null || true)"
      project="$(cat "$prepare_dir/project" 2>/dev/null || true)"
      detail="$(cat "$prepare_dir/detail" 2>/dev/null || true)"
      tool="$(cat "$prepare_dir/tool" 2>/dev/null || true)"
      if [ -z "$title" ] || [ -z "$body" ]; then
        status=1
        printf '%s\n' "prepared notification was incomplete" >> "$output_file" 2>/dev/null || true
      else
        log_notification_attempt "$event" "$backend" "$project" "$tool" "$detail"
        notifier_args=(-title "$title" -message "$body" -group "codex-alarm-$event")
        [ -n "$CODEX_ALARM_SOUND" ] && notifier_args+=(-sound "$CODEX_ALARM_SOUND")
        [ -n "$bundle_id" ] && notifier_args+=(-activate "$bundle_id")
        run_process_group_with_timeout "$CODEX_ALARM_BACKEND_TIMEOUT_SECONDS" "$output_file" \
          "$notifier_path" "${notifier_args[@]}"
        status=$?

        if [ "$status" -eq 0 ] && [ "$event" = "permission" ] && [ -n "$fingerprint" ]; then
          remember_output="${TMPDIR:-/tmp}/codex-alarm-backend.$$.$event.remember.log"
          run_with_timeout "$CODEX_ALARM_BACKEND_TIMEOUT_SECONDS" "$remember_output" \
            /usr/bin/osascript -l JavaScript "$script_file" "$event" "$backend" "$bundle_id" "$CODEX_ALARM_SOUND" "$CODEX_ALARM_HOME" "$dry_run" "$fingerprint" "" "remember" || true
          rm -f "$remember_output" 2>/dev/null || true
        fi
      fi
    fi

    rm -rf "$prepare_dir" 2>/dev/null || true
  else
    if [ "$dry_run" != "1" ]; then
      case "$event" in
        stop|permission)
          prepare_dir="${TMPDIR:-/tmp}/codex-alarm-prepare.$$.$event.$backend"
          mkdir -p "$prepare_dir" 2>/dev/null || true
          run_with_timeout "$CODEX_ALARM_BACKEND_TIMEOUT_SECONDS" "$output_file" \
            /usr/bin/osascript -l JavaScript "$script_file" "$event" "$backend" "$bundle_id" "$CODEX_ALARM_SOUND" "$CODEX_ALARM_HOME" "$dry_run" "$payload_file" "$prepare_dir" "prepare"
          status=$?
          if [ "$status" -eq 0 ]; then
            suppressed="$(cat "$prepare_dir/suppressed" 2>/dev/null || true)"
            if [ "$suppressed" = "1" ]; then
              rm -rf "$prepare_dir" 2>/dev/null || true
              rm -f "$output_file" "$script_file" 2>/dev/null || true
              return 0
            fi
            project="$(cat "$prepare_dir/project" 2>/dev/null || true)"
            detail="$(cat "$prepare_dir/detail" 2>/dev/null || true)"
            tool="$(cat "$prepare_dir/tool" 2>/dev/null || true)"
            log_notification_attempt "$event" "$backend" "$project" "$tool" "$detail"
          else
            rm -rf "$prepare_dir" 2>/dev/null || true
            if [ "$status" -eq 124 ]; then
              message="backend=$backend event=$event timed out after ${CODEX_ALARM_BACKEND_TIMEOUT_SECONDS}s"
            else
              message="backend=$backend event=$event failed with exit $status"
            fi
            log_message "$message"
            rm -f "$output_file" "$script_file" 2>/dev/null || true
            return "$status"
          fi
          rm -rf "$prepare_dir" 2>/dev/null || true
          ;;
      esac
    fi

    run_with_timeout "$CODEX_ALARM_BACKEND_TIMEOUT_SECONDS" "$output_file" \
      /usr/bin/osascript -l JavaScript "$script_file" "$event" "$backend" "$bundle_id" "$CODEX_ALARM_SOUND" "$CODEX_ALARM_HOME" "$dry_run" "$payload_file" "$notifier_path" "send"
    status=$?
  fi

  if should_print_backend_output "$event"; then
    cat "$output_file" 2>/dev/null || true
  fi

  if [ "$status" -ne 0 ]; then
    if [ "$status" -eq 124 ]; then
      message="backend=$backend event=$event timed out after ${CODEX_ALARM_BACKEND_TIMEOUT_SECONDS}s"
    else
      message="backend=$backend event=$event failed with exit $status"
    fi
    log_message "$message"
    if [ -s "$output_file" ]; then
      while IFS= read -r line || [ -n "$line" ]; do
        log_message "backend output: $line"
      done < "$output_file"
    fi
    if should_print_backend_output "$event"; then
      echo "ERROR $message" >&2
      echo "See $CODEX_ALARM_HOME/alarm.log for details." >&2
    fi
  fi

  rm -f "$output_file" 2>/dev/null || true
  rm -f "$script_file" 2>/dev/null || true
  return "$status"
}

run_notification() {
  local event="$1"
  local payload_file backend bundle_id notifier_path dry_run status primary_status fallback_status fallback_reason

  case "$event" in
    stop)
      [ "$CODEX_ALARM_NOTIFY_ON_STOP" = "1" ] || return 0
      ;;
    permission)
      [ "$CODEX_ALARM_NOTIFY_ON_PERMISSION" = "1" ] || return 0
      ;;
  esac

  if ! command_exists /usr/bin/osascript; then
    log_message "backend unavailable: /usr/bin/osascript missing"
    if should_print_backend_output "$event"; then
      echo "ERROR backend unavailable: /usr/bin/osascript missing" >&2
    fi
    return 1
  fi

  mkdir -p "$CODEX_ALARM_HOME" 2>/dev/null || true

  payload_file="${TMPDIR:-/tmp}/codex-alarm-payload.$$"
  cat > "$payload_file" 2>/dev/null || payload_file=""

  backend="$(resolve_backend)"
  bundle_id="$(detect_bundle_id)"
  notifier_path=""
  if [ "$backend" = "terminal-notifier" ]; then
    notifier_path="$(command -v terminal-notifier 2>/dev/null || true)"
    if [ -z "$notifier_path" ]; then
      log_message "backend=terminal-notifier event=$event unavailable: terminal-notifier not found"
      if osascript_fallback_allowed; then
        log_message "event=$event primary_backend=terminal-notifier fallback_backend=osascript fallback_attempt=1 reason=missing"
        if should_print_backend_output "$event"; then
          echo "WARN terminal-notifier not found; retrying osascript fallback." >&2
        fi
        run_notification_once "$event" "osascript" "$bundle_id" "$payload_file" "" "${CODEX_ALARM_DRY_RUN:-0}"
        fallback_status=$?
        if should_print_backend_output "$event" && [ "$fallback_status" -eq 0 ]; then
          echo "WARN osascript fallback delivered after primary backend terminal-notifier was unavailable; alarm test will still fail." >&2
        fi
        [ -n "$payload_file" ] && rm -f "$payload_file" 2>/dev/null || true
        if is_test_event "$event"; then
          return 1
        fi
        return "$fallback_status"
      else
        if should_print_backend_output "$event"; then
          echo "ERROR backend=terminal-notifier event=$event unavailable: terminal-notifier not found" >&2
          echo "ERROR osascript fallback is disabled by CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK=0." >&2
          echo "See $CODEX_ALARM_HOME/alarm.log for details." >&2
        fi
        [ -n "$payload_file" ] && rm -f "$payload_file" 2>/dev/null || true
        return 1
      fi
    fi
  fi
  dry_run="${CODEX_ALARM_DRY_RUN:-0}"

  run_notification_once "$event" "$backend" "$bundle_id" "$payload_file" "$notifier_path" "$dry_run"
  status=$?

  if [ "$status" -ne 0 ] && [ "$backend" = "terminal-notifier" ]; then
    if ! osascript_fallback_allowed; then
      log_message "backend=terminal-notifier event=$event failed; osascript fallback disabled"
      if should_print_backend_output "$event"; then
        echo "ERROR osascript fallback is disabled by CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK=0." >&2
        echo "See $CODEX_ALARM_HOME/alarm.log for details." >&2
      fi
    elif should_retry_osascript_fallback "$event"; then
      primary_status=$status
      if [ "$status" -eq 124 ]; then
        fallback_reason="timed out"
        log_message "event=$event primary_backend=terminal-notifier fallback_backend=osascript fallback_attempt=1 reason=timeout"
      else
        fallback_reason="failed"
        log_message "event=$event primary_backend=terminal-notifier fallback_backend=osascript fallback_attempt=1 reason=failed"
      fi
      if should_print_backend_output "$event"; then
        if [ "$status" -eq 124 ]; then
          echo "WARN terminal-notifier timed out; retrying osascript fallback." >&2
        else
          echo "WARN terminal-notifier failed; retrying osascript fallback." >&2
        fi
      fi
      run_notification_once "$event" "osascript" "$bundle_id" "$payload_file" "" "$dry_run"
      fallback_status=$?
      if should_print_backend_output "$event"; then
        if [ "$fallback_status" -eq 0 ]; then
          echo "WARN osascript fallback delivered after primary backend terminal-notifier $fallback_reason; alarm test will still fail." >&2
        else
          echo "ERROR osascript fallback also failed after primary backend terminal-notifier $fallback_reason." >&2
        fi
      fi
      if is_test_event "$event"; then
        status=$primary_status
      else
        status=$fallback_status
      fi
    else
      log_message "backend=terminal-notifier event=$event timed out; skipping osascript fallback to stay within hook timeout"
    fi
  fi

  [ -n "$payload_file" ] && rm -f "$payload_file" 2>/dev/null || true
  return "$status"
}

doctor() {
  local exit_code=0 backend bundle_id hooks_file installed_path has_stop_hook has_permission_hook
  backend="$(resolve_backend)"
  bundle_id="$(detect_bundle_id)"
  hooks_file="$CODEX_HOME/hooks.json"
  installed_path="$CODEX_ALARM_HOME/alarm"

  echo "Codex Alarm doctor"
  echo "version: $VERSION"
  echo "local-only: no telemetry, no network requests"
  if [ "$(uname -s)" = "Darwin" ]; then
    echo "platform: macOS supported"
  else
    echo "ERROR platform unsupported: $(uname -s)"
    exit_code=1
  fi
  echo "CODEX_HOME: $CODEX_HOME"
  echo "CODEX_ALARM_HOME: $CODEX_ALARM_HOME"
  echo "config file: $CONFIG_FILE"
  echo "hooks file: $hooks_file"
  echo "installed executable: $installed_path"
  echo "backend configured: $CODEX_ALARM_BACKEND"
  echo "backend resolved: $backend"
  echo "notify on stop: $CODEX_ALARM_NOTIFY_ON_STOP"
  echo "notify on permission: $CODEX_ALARM_NOTIFY_ON_PERMISSION"
  echo "sound: $CODEX_ALARM_SOUND"
  echo "activate bundle ID: ${bundle_id:-<not configured>}"
  echo "backend timeout seconds: $CODEX_ALARM_BACKEND_TIMEOUT_SECONDS"
  echo "osascript fallback: $([ "$CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK" = "1" ] && echo enabled || echo disabled)"
  echo "log file: $CODEX_ALARM_HOME/alarm.log"
  echo "hooks scope: user-level global hooks may notify from any active Codex session using $CODEX_HOME"

  if [ -n "$CONFIG_ERROR" ]; then
    echo "ERROR config invalid: $CONFIG_ERROR"
    exit_code=1
  fi

  if command_exists /usr/bin/osascript; then
    echo "osascript: found"
  else
    echo "ERROR osascript: missing"
    exit_code=1
  fi

  if command_exists terminal-notifier; then
    echo "terminal-notifier: found"
  else
    if [ "$backend" = "terminal-notifier" ]; then
      echo "WARN terminal-notifier missing: default notification backend unavailable"
    else
      echo "WARN terminal-notifier missing: click-to-focus unavailable"
    fi
    echo "Install manually with: brew install terminal-notifier"
  fi

  if [ "$backend" = "osascript" ]; then
    echo "WARN osascript backend: notification identity and click-to-focus are degraded"
  fi

  if osascript_fallback_allowed; then
    echo "WARN osascript fallback enabled: terminal-notifier failures may produce generic script-identity notifications"
  fi

  if command_exists codex; then
    echo "codex: found"
  else
    echo "WARN codex not found on PATH: cannot verify CLI availability"
  fi

  if [ -f "$CONFIG_FILE" ]; then
    echo "config: found"
  else
    echo "WARN config missing: $CONFIG_FILE"
  fi

  if [ -f "$installed_path" ]; then
    echo "installed executable status: found"
  elif [ "$0" = "$installed_path" ]; then
    echo "ERROR installed executable status: missing"
    exit_code=1
  else
    echo "WARN installed executable status: not found"
  fi

  if [ -f "$hooks_file" ]; then
    if hook_report="$(/usr/bin/osascript -l JavaScript - "$hooks_file" "$installed_path" 2>/dev/null <<'JXA'
function run(argv) {
  var path = argv[0];
  var alarmPath = argv[1] || '';
  ObjC.import('Foundation');
  var text = ObjC.unwrap($.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, null));
  var doc = JSON.parse(text || '{}');
  var hooks = doc && doc.hooks && typeof doc.hooks === 'object' && !Array.isArray(doc.hooks) ? doc.hooks : {};
  var alarmCount = 0;
  var stopCount = 0;
  var permissionCount = 0;
  function hasInstalledCommand(command, subcommand) {
    if (!alarmPath || command.indexOf(alarmPath) === -1) return false;
    var rest = command.slice(command.indexOf(alarmPath) + alarmPath.length).trim();
    if (rest.charCodeAt(0) === 34 || rest.charCodeAt(0) === 39) {
      rest = rest.slice(1).trim();
    }
    return rest.split(/\s+/)[0] === subcommand;
  }
  Object.keys(hooks).forEach(function(eventName) {
    var groups = Array.isArray(hooks[eventName]) ? hooks[eventName] : [];
    groups.forEach(function(group) {
      var entries = group && Array.isArray(group.hooks) ? group.hooks : [];
      entries.forEach(function(hook) {
        var command = String((hook && hook.command) || '');
        var status = String((hook && (hook.statusMessage || hook.status_message)) || '');
        if (status.indexOf('Codex Alarm:') === 0 ||
            command.indexOf('/alarm/alarm') !== -1 ||
            (alarmPath && command.indexOf(alarmPath) !== -1)) {
          alarmCount++;
        }
        if (eventName === 'Stop' && hasInstalledCommand(command, 'stop')) {
          stopCount++;
        }
        if (eventName === 'PermissionRequest' && hasInstalledCommand(command, 'permission')) {
          permissionCount++;
        }
      });
    });
  });
  return [
    'hooks: Codex Alarm entries ' + alarmCount,
    'hooks: Stop hook entries ' + stopCount,
    'hooks: PermissionRequest hook entries ' + permissionCount
  ].join('\n');
}
JXA
)"
    then
      echo "hooks.json: valid JSON"
      echo "$hook_report"
      if grep -q '^hooks: Codex Alarm entries [1-9]' <<<"$hook_report"; then
        echo "hooks: Codex Alarm entries found"
      else
        echo "WARN hooks: Codex Alarm entries not found"
      fi
      has_stop_hook=0
      has_permission_hook=0
      grep -q '^hooks: Stop hook entries [1-9]' <<<"$hook_report" && has_stop_hook=1
      grep -q '^hooks: PermissionRequest hook entries [1-9]' <<<"$hook_report" && has_permission_hook=1
      if [ "$has_stop_hook" -eq 1 ] && [ "$has_permission_hook" -eq 1 ]; then
        echo "hooks: required entries present"
      fi
      if [ "$has_stop_hook" -eq 0 ]; then
        echo "WARN hooks: Stop hook not found"
      fi
      if [ "$has_permission_hook" -eq 0 ]; then
        echo "WARN hooks: PermissionRequest hook not found"
      fi
    else
      echo "ERROR hooks.json is invalid JSON: $hooks_file"
      exit_code=1
    fi
  else
    echo "WARN hooks.json missing: $hooks_file"
  fi

  [ -n "$bundle_id" ] || echo "WARN no activate bundle ID configured: click-to-focus may be unavailable"
  echo "Run /hooks inside Codex to verify the Codex Alarm hooks are trusted."
  return "$exit_code"
}

usage() {
  cat <<'EOF'
Usage: alarm <command>

Commands:
  stop        Codex Stop hook entrypoint
  permission  Codex PermissionRequest hook entrypoint
  test        Send test notifications
  doctor      Print diagnostics
  version     Print version
EOF
}

load_config
apply_env_overrides

case "${1-}" in
  stop)
    run_notification stop || true
    exit 0
    ;;
  permission)
    run_notification permission || true
    exit 0
    ;;
  test)
    test_status=0
    echo "Codex Alarm test: osascript fallback $([ "$CODEX_ALARM_ALLOW_OSASCRIPT_FALLBACK" = "1" ] && echo enabled || echo disabled)"
    printf '' | run_notification test || test_status=1
    sleep 1
    printf '' | run_notification test-permission || test_status=1
    exit "$test_status"
    ;;
  doctor)
    doctor
    ;;
  version)
    echo "$VERSION"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
